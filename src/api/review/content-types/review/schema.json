{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Reviews"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "text": {
      "type": "text"
    },
    "rate": {
      "type": "integer",
      "default": 5
    },
    "link": {
      "type": "string"
    },
    "reviews_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::reviews-category.reviews-category",
      "inversedBy": "reviews"
    },
    "date": {
      "type": "date"
    }
  }
}
