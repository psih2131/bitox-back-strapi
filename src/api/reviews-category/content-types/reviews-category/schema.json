{
  "kind": "collectionType",
  "collectionName": "reviews_categories",
  "info": {
    "singularName": "reviews-category",
    "pluralName": "reviews-categories",
    "displayName": "reviews_category"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name_category": {
      "type": "string"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "reviews_category"
    },
    "img": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "rate_category": {
      "type": "decimal"
    },
    "link": {
      "type": "string"
    }
  }
}
