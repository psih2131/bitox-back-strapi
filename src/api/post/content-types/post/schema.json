{
  "kind": "collectionType",
  "collectionName": "blog",
  "info": {
    "singularName": "post",
    "pluralName": "blog",
    "displayName": "blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "post_title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 255,
      "required": true
    },
    "post_description": {
      "type": "text"
    },
    "slug": {
      "type": "uid",
      "targetField": "post_title",
      "required": true
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "blogs"
    },
    "post_image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "post_content_builder": {
      "type": "dynamiczone",
      "components": [
        "shared.quote-text",
        "shared.text-editor"
      ]
    },
    "post_questions_section": {
      "type": "component",
      "component": "shared.post-questions",
      "repeatable": false
    },
    "seo_cluster": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "time_read_post": {
      "type": "string",
      "default": "5"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "blogs"
    }
  }
}
