{
  "kind": "collectionType",
  "collectionName": "services_categories",
  "info": {
    "singularName": "services-category",
    "pluralName": "services-categories",
    "displayName": "Services category"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "text"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "services": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service.service",
      "mappedBy": "services_category"
    }
  }
}
